{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Ansible Playbook",
            "type": "shell",
            "command": "ansible-playbook",
            "args": [
                "--inventory",
                "inventory",
                "westsidestreet.net.yaml"
            ],
            "options": {
                "cwd": "${workspaceFolder}/ansible"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
